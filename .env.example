# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
# Local dev: docker compose publishes Postgres on host port 5433 (5432 inside).
DATABASE_URL="postgresql://birkityt:birkityt@localhost:5433/birkityt?schema=public"

# --- Auth.js ---
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-please-generate-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# --- First admin (used by `npm run db:seed`) ---
ADMIN_EMAIL="admin@birkityt.ru"
ADMIN_PASSWORD="change-me-please"

# --- SMTP (email notifications, stage 2) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Birkityt <no-reply@birkityt.ru>"
MAIL_TO="orders@birkityt.ru"

# --- Telegram (notifications, stage 2) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Uploads ---
UPLOAD_DIR="./uploads"
