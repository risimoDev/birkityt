# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
# Local dev: docker compose publishes Postgres on host port 5433 (5432 inside).
DATABASE_URL="postgresql://birkityt:birkityt@localhost:5433/birkityt?schema=public"

# --- Domain & HTTPS (Let's Encrypt via Caddy) ---
# Your real domain. DNS A/AAAA record must point to this server, ports 80+443 open.
# Caddy auto-issues a Let's Encrypt certificate for it.
# Use "localhost" for local testing (Caddy serves a self-signed cert).
DOMAIN="birkityt.ru"
# Email for the Let's Encrypt account (expiry notices). Recommended.
ACME_EMAIL="admin@birkityt.ru"

# --- Auth.js ---
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-please-generate-a-long-random-secret"
# In production set this to your HTTPS URL, e.g. https://birkityt.ru
AUTH_URL="https://birkityt.ru"

# --- First admin (used by `npm run db:seed`) ---
ADMIN_EMAIL="admin@birkityt.ru"
ADMIN_PASSWORD="change-me-please"

# --- SMTP (email notifications, stage 2) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Birkityt <no-reply@birkityt.ru>"
MAIL_TO="orders@birkityt.ru"

# --- Telegram (notifications, stage 2) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Uploads ---
UPLOAD_DIR="./uploads"
